<title>AI Builders Digest</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --bg: #f7f5f2; --surface: #fff; --surface-hover: #faf8f6;
  --card: #fff; --text-primary: #1a1a1a; --text-secondary: #5c5c5c;
  --text-muted: #999; --accent: #c47a2a; --accent-light: #faf0e3;
  --accent-border: rgba(196,122,42,0.2); --border: #e8e5e0;
  --tag-twitter: #1a8cd8; --tag-podcast: #9333ea;
  --font-serif: 'Noto Serif SC', Georgia, serif;
  --font-sans: 'Noto Sans SC', -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
}
html { font-size: 16px; scroll-behavior: smooth; }
body { font-family: var(--font-sans); background: var(--bg); color: var(--text-primary); line-height: 1.7; min-height: 100vh; -webkit-font-smoothing: antialiased; }

.header { position: sticky; top: 0; z-index: 100; background: rgba(247,245,242,0.88); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); padding: 0 2rem; }
.header-inner { max-width: 760px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 60px; }
.logo { display: flex; align-items: center; gap: 0.7rem; }
.logo-mark { width: 34px; height: 34px; border-radius: 10px; background: linear-gradient(135deg, #c47a2a, #e8a849); display: flex; align-items: center; justify-content: center; font-size: 0.95rem; font-weight: 700; color: #fff; font-family: var(--font-serif); }
.logo-text { display: flex; flex-direction: column; line-height: 1.2; }
.logo-title { font-family: var(--font-serif); font-weight: 700; font-size: 0.95rem; color: var(--text-primary); }
.logo-sub { font-size: 0.62rem; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase; }
.header-date { font-size: 0.82rem; color: var(--text-secondary); font-family: var(--font-mono); }

.hero { max-width: 760px; margin: 0 auto; padding: 3rem 2rem 0; }
.hero-date { font-family: var(--font-serif); font-size: 3rem; font-weight: 700; color: var(--accent); line-height: 1.1; }
.hero-sub { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem; font-weight: 300; }
.hero-line { height: 1px; background: linear-gradient(90deg, var(--accent) 0%, transparent 60%); margin-top: 1.5rem; opacity: 0.25; }

.main { max-width: 760px; margin: 0 auto; padding: 2rem 2rem 4rem; }

.digest-section { margin-bottom: 3rem; opacity: 0; transform: translateY(14px); animation: fadeUp 0.5s ease forwards; }
.digest-section:nth-child(1) { animation-delay: 0.05s; }
.digest-section:nth-child(2) { animation-delay: 0.15s; }
@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

.section-label { display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1.2rem; }
.section-dot { width: 8px; height: 8px; border-radius: 50%; }
.section-dot.twitter { background: var(--tag-twitter); box-shadow: 0 0 8px rgba(26,140,216,0.3); }
.section-dot.podcast { background: var(--tag-podcast); box-shadow: 0 0 8px rgba(147,51,234,0.3); }
.section-name { font-size: 0.72rem; font-weight: 600; color: var(--text-secondary); letter-spacing: 0.1em; text-transform: uppercase; }

.card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 1.3rem 1.5rem; margin-bottom: 0.7rem; transition: all 0.2s; }
.card:hover { border-color: var(--accent-border); background: var(--surface-hover); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
.card-author { font-size: 0.78rem; font-weight: 600; color: var(--accent); margin-bottom: 0.45rem; display: flex; align-items: center; gap: 0.5rem; }
.card-author .role { font-weight: 400; color: var(--text-muted); font-size: 0.72rem; }
.card-body { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.75; }
.card-body strong { color: var(--text-primary); font-weight: 500; }
.card-link { display: inline-flex; align-items: center; gap: 0.3rem; margin-top: 0.65rem; font-size: 0.72rem; color: var(--text-muted); text-decoration: none; transition: color 0.2s; font-family: var(--font-mono); }
.card-link:hover { color: var(--accent); }
.card-link svg { width: 12px; height: 12px; }

.podcast-card { background: linear-gradient(135deg, rgba(147,51,234,0.04), rgba(147,51,234,0.01)); border-color: rgba(147,51,234,0.12); }
.podcast-card:hover { border-color: rgba(147,51,234,0.25); }
.podcast-title { font-size: 0.9rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.3rem; }
.podcast-show { font-size: 0.75rem; color: var(--tag-podcast); margin-bottom: 0.8rem; font-weight: 500; }
.podcast-points { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; }
.podcast-points li { font-size: 0.85rem; color: var(--text-secondary); padding-left: 1.2rem; position: relative; line-height: 1.7; }
.podcast-points li::before { content: ''; position: absolute; left: 0; top: 0.55em; width: 5px; height: 5px; border-radius: 50%; background: var(--tag-podcast); opacity: 0.5; }
.podcast-points li strong { color: var(--text-primary); }
.podcast-quote { margin: 1rem 0; padding: 0.8rem 1rem; border-left: 3px solid var(--tag-podcast); background: rgba(147,51,234,0.04); border-radius: 0 8px 8px 0; font-size: 0.85rem; color: var(--text-secondary); font-style: italic; line-height: 1.8; }

/* Side nav buttons */
.side-nav {
  position: fixed; top: 50%; z-index: 90;
  transform: translateY(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
  width: 56px; height: 140px;
  justify-content: center;
}
.side-nav.left { left: 0; }
.side-nav.right { right: 0; }

.nav-arrow-btn {
  width: 44px; height: 44px;
  border-radius: 50%;
  border: 1.5px solid var(--border);
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: var(--text-secondary);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.nav-arrow-btn svg { width: 18px; height: 18px; }
.nav-arrow-btn:hover:not(:disabled) {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(255,255,255,0.95);
  transform: scale(1.12);
  box-shadow: 0 4px 20px rgba(196,122,42,0.15);
}
.nav-arrow-btn:active:not(:disabled) {
  transform: scale(0.95);
  transition-duration: 0.1s;
}
.nav-arrow-btn:disabled {
  opacity: 0; pointer-events: none;
}

.nav-label {
  font-size: 0.6rem;
  color: var(--text-muted);
  writing-mode: vertical-lr;
  letter-spacing: 0.08em;
  font-family: var(--font-sans);
  white-space: nowrap;
  transition: opacity 0.3s;
  opacity: 0;
}
.side-nav:hover .nav-label { opacity: 1; }
.nav-arrow-btn:disabled ~ .nav-label { opacity: 0 !important; }

/* Slide transition for content */
.page-wrapper {
  transition: opacity 0.25s ease, transform 0.25s ease;
}
.page-wrapper.slide-left { opacity: 0; transform: translateX(-20px); }
.page-wrapper.slide-right { opacity: 0; transform: translateX(20px); }

.footer { max-width: 760px; margin: 0 auto; padding: 0 2rem 4rem; text-align: center; }
.footer-line { height: 1px; background: var(--border); margin-bottom: 1.5rem; }
.footer-text { font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.06em; }

::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

@media (max-width: 640px) {
  .header { padding: 0 1rem; }
  .hero { padding: 2rem 1rem 0; }
  .main { padding: 1.5rem 1rem 3rem; }
  .hero-date { font-size: 2.2rem; }
  .card { padding: 1rem 1.2rem; }
  .logo-sub { display: none; }
  .side-nav { width: 40px; }
  .nav-arrow-btn { width: 36px; height: 36px; }
  .nav-arrow-btn svg { width: 14px; height: 14px; }
  .nav-label { display: none; }
}
</style>
</head>
