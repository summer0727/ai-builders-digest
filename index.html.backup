var dates = Object.keys(digests).sort().reverse();
var idx = 0;
var sliding = false;
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function render(){
  var dk=dates[idx], d=digests[dk];
  document.getElementById('headerDate').textContent=d.date;
  document.title='AI Builders Digest - '+d.date;
  var h='<div class="hero"><div class="hero-date">'+esc(d.date)+'</div><div class="hero-sub">'+esc(d.heroSub)+'</div><div class="hero-line"></div></div><div class="main">';
  if(d.twitter&&d.twitter.length){h+='<div class="digest-section"><div class="section-label"><div class="section-dot twitter"></div><div class="section-name">X / Twitter</div></div>';for(var i=0;i<d.twitter.length;i++){var t=d.twitter[i];h+='<div class="card"><div class="card-author">'+esc(t.author)+(t.role?' <span class="role">/ '+esc(t.role)+'</span>':'')+'</div><div class="card-body">'+t.text+'</div><a class="card-link" href="'+esc(t.url)+'" target="_blank"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg> 查看原文</a></div>';}h+='</div>';}
  if(d.podcasts&&d.podcasts.length){h+='<div class="digest-section"><div class="section-label"><div class="section-dot podcast"></div><div class="section-name">Podcasts</div></div>';for(var i=0;i<d.podcasts.length;i++){var p=d.podcasts[i];h+='<div class="card podcast-card"><div class="podcast-title">'+esc(p.title)+'</div><div class="podcast-show">'+esc(p.show)+'</div><ul class="podcast-points">';for(var j=0;j<p.points.length;j++){h+='<li>'+p.points[j]+'</li>';}h+='</ul>';if(p.quote){h+='<div class="podcast-quote">'+p.quote+'</div>';}h+='<a class="card-link" href="'+esc(p.url)+'" target="_blank"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg> 收听完整播客</a></div>';}h+='</div>';}
  h+='</div>';
  document.getElementById('content').innerHTML=h;
  var total=dates.length;
  var hasNewer=idx<total-1, hasOlder=idx>0;
  document.getElementById('prevBtn').disabled=!hasNewer;
  document.getElementById('nextBtn').disabled=!hasOlder;
  document.getElementById('navLeftLabel').textContent=hasNewer?digests[dates[idx+1]].date:'';
  document.getElementById('navRightLabel').textContent=hasOlder?digests[dates[idx-1]].date:'';
}
function go(dir){
  if(sliding) return;
  var ni=idx+dir;
  if(ni<0||ni>=dates.length) return;
  sliding=true;
  var pw=document.getElementById('pageWrapper');
  pw.classList.add(dir>0?'slide-left':'slide-right');
  setTimeout(function(){
    idx=ni;
    render();
    window.scrollTo({top:0,behavior:'instant'});
    pw.classList.remove('slide-left','slide-right');
    pw.classList.add(dir>0?'slide-right':'slide-left');
    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        pw.classList.remove('slide-left','slide-right');
        sliding=false;
      });
    });
  },260);
}
document.addEventListener('keydown',function(e){if(e.key==='ArrowLeft')go(1);if(e.key==='ArrowRight')go(-1);});
render();
</script>
</body>
</html>
